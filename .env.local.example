# ─── Wedding Gallery ──────────────────────────────────────────────────────────

# Gallery password (hashed with bcrypt).
# To generate: node -e "require('bcryptjs').hash('your-password', 12).then(console.log)"
GALLERY_PASSWORD_HASH=

# iron-session secret — must be at least 32 random characters.
# To generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Find your Account ID in the Cloudflare dashboard → R2 → Overview (right sidebar).
R2_ACCOUNT_ID=

# Create an API token at: Cloudflare → R2 → Manage R2 API Tokens
# Grant "Object Read & Write" on your bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# The name of your R2 bucket (e.g. wedding-photos)
R2_BUCKET_NAME=
